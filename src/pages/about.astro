---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_LOCALE, SITE_TITLE } from "../consts";
---

<!doctype html>
<html lang={SITE_LOCALE}>
	<head>
		<BaseHead title={`关于 | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="section">
			<div class="content-article">
				<span class="eyebrow">About</span>
				<h1>关于本站</h1>
				<p class="lead">
					这里整理主机、云服务和建站相关优惠，同时补充选购建议和避坑内容。
				</p>
				<div class="content-body">
					<h2>内容方向</h2>
					<ul>
						<li>限时优惠、补货活动和新用户促销</li>
						<li>商家索引、支付方式和适用人群</li>
						<li>VPS 选购、建站方案和避坑建议</li>
					</ul>

					<h2>适合谁看</h2>
					<ul>
						<li>想找便宜 VPS 的入门用户</li>
						<li>准备搭博客、导航站或轻量服务的人</li>
						<li>需要先比较节点、续费和口碑再下单的人</li>
					</ul>

					<h2>说明</h2>
					<ul>
						<li>优惠会随库存和活动周期变化，购买前请以商家页面为准</li>
						<li>续费价格、线路表现和售后响应建议自行复核</li>
						<li>如果活动失效，可优先查看最新优惠页</li>
					</ul>
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>
