---
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import { SITE_LOCALE, SITE_TITLE } from "../../consts";
import { getCollection } from "astro:content";
import { sortGuidesByDate } from "../../lib/content";

const guides = sortGuidesByDate(await getCollection("guides"));
---

<!doctype html>
<html lang={SITE_LOCALE}>
	<head>
		<BaseHead
			title={`教程与攻略 | ${SITE_TITLE}`}
			description="给新手的 VPS 选购、优惠识别和避坑内容。"
		/>
	</head>
	<body>
		<Header />
		<main class="section">
			<div class="shell">
				<div class="section-header">
					<div>
						<span class="eyebrow">Guides</span>
						<h1>教程与攻略</h1>
						<p class="muted">教程页负责承接搜索流量，也能给优惠页补充信任感。</p>
					</div>
				</div>
				<div class="grid grid-2">
					{
						guides.map((guide) => (
							<article class="card">
								<img src={guide.data.heroImage} alt={guide.data.title} />
								<h2>
									<a href={`/guides/${guide.id}/`}>{guide.data.title}</a>
								</h2>
								<p>{guide.data.description}</p>
								<div class="badge-row">
									<span class="tag">{guide.data.category}</span>
									{guide.data.tags.map((tag) => <span class="tag">{tag}</span>)}
								</div>
							</article>
						))
					}
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>
