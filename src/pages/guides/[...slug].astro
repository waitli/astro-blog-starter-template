---
import { getCollection, render, type CollectionEntry } from "astro:content";
import ContentPage from "../../layouts/ContentPage.astro";

export async function getStaticPaths() {
	const guides = await getCollection("guides");
	return guides.map((guide) => ({
		params: { slug: guide.id },
		props: guide,
	}));
}

type Props = CollectionEntry<"guides">;

const guide = Astro.props;
const { Content } = await render(guide);
const meta = [guide.data.category, ...guide.data.tags];
---

<ContentPage
	title={guide.data.title}
	description={guide.data.description}
	image={guide.data.heroImage}
	label="教程"
	publishedAt={guide.data.publishedAt}
	updatedAt={guide.data.updatedAt}
	meta={meta}
>
	<Content />
</ContentPage>
