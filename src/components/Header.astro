---
import HeaderLink from "./HeaderLink.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
---

<header class="site-header">
	<div class="shell header-shell">
		<div class="brand">
			<a href="/" class="brand-link">{SITE_TITLE}</a>
			<p>{SITE_DESCRIPTION}</p>
		</div>
		<nav class="nav-links" aria-label="Main navigation">
			<HeaderLink href="/">首页</HeaderLink>
			<HeaderLink href="/deals">优惠</HeaderLink>
			<HeaderLink href="/vendors">商家</HeaderLink>
			<HeaderLink href="/guides">教程</HeaderLink>
			<HeaderLink href="/about">关于</HeaderLink>
		</nav>
	</div>
</header>
