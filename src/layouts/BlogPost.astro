---
import ContentPage from "./ContentPage.astro";

interface Props {
	title: string;
	description: string;
	heroImage?: string;
	pubDate?: Date;
	updatedDate?: Date;
}

const { title, description, heroImage, pubDate, updatedDate } = Astro.props;
---

<ContentPage
	title={title}
	description={description}
	image={heroImage}
	label="内容"
	publishedAt={pubDate}
	updatedAt={updatedDate}
>
	<slot />
</ContentPage>
